{
  "name": "@capogreco/ptouch",
  "version": "0.1.2",
  "license": "MIT",
  "exports": {
    ".": "./mod.ts",
    "./cli": "./cli.ts"
  },
  "exclude": [".claude/"],
  "tasks": {
    "print": "deno run --allow-all cli.ts",
    "status": "deno run --allow-all cli.ts status",
    "fonts": "deno run --allow-all cli.ts fonts",
    "models": "deno run --allow-all cli.ts models",
    "install": "deno install --allow-all --global --name ptouch cli.ts"
  }
}
